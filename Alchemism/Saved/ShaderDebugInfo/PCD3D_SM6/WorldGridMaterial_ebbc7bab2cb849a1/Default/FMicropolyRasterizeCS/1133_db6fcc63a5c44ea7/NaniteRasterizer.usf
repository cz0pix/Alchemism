		Tri.Verts[2].TangentBasis,
		Barycentrics,
		InstanceData,
		NumAttributeDataCoords
	);







	Result.VertexColor = float4(1, 1, 1, 1);
	Result.VertexColor_DDX = 0.0f;
	Result.VertexColor_DDY = 0.0f;


	Result.TangentToWorld = AttributeData.TangentToWorld;
