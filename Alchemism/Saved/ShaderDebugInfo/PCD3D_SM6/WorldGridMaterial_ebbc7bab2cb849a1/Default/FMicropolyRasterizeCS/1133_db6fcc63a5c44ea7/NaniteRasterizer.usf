struct FCachedPageTable
{
	bool operator()( inout FVisBufferPixel Pixel )
	{

		uint2 pPage = VsmPageTableLoad(Pixel.Position / (1u << 7u));
		if (pPage.x == 0xffff)
		{
			return false;
		}
		Pixel.PhysicalPosition.xy = pPage * (1u << 7u) + (Pixel.Position & ((1u << 7u) - 1u));

		return true;
	}
};

